# ISOSerial Provenance Crawler — required env vars
# Copy these into your repo-root .env (append, don't replace — ISOsnipe already uses EBAY_*).

# eBay Browse API (reused from ISOsnipe — already set)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# Supabase — needed for writing to iso_serial_queue / iso_serial_pulls
# Use the SERVICE ROLE key (not anon) so writes bypass RLS.
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# Anthropic API key — optional, enables AI pre-classification of listings.
# When set, every new listing gets classified by Claude Haiku 4.5 and
# the result is stored in iso_serial_queue.ai_classification (JSONB).
# The admin review modal pre-fills dropdowns from this. Without it,
# the crawler runs as before with no classification.
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
